# ===== 必填 =====
NUM_WORKERS_PER_QUEUE=8
PORT=3002
HOST=0.0.0.0
REDIS_URL=redis://redis:6379
REDIS_RATE_LIMIT_URL=redis://redis:6379
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape

# ===== 可选：搜索引擎 =====
# SearXNG（自部署搜索后端）
SEARXNG_ENDPOINT=http://searxng:8080
SEARXNG_ENGINES=baidu,sogou,360search,quark,bing,google,duckduckgo,brave
SEARXNG_CATEGORIES=general

# SearchApi（https://searchapi.com/）
SEARCHAPI_API_KEY=
SEARCHAPI_ENGINE=

# ===== 可选：AI 功能 =====
# 用于 extract（LLM 模式）和 summary 端点
# 支持 OpenAI 或 Ollama，二选一即可
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# ===== 可选：GitHub =====
# 提高 GitHub API 速率限制（无 token 时 60 次/小时，有 token 5000 次/小时）
GITHUB_TOKEN=

# ===== 可选：性能 =====
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

# ===== 可选：代理 =====
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
BLOCK_MEDIA=

# ===== 可选：Webhook =====
SELF_HOSTED_WEBHOOK_URL=
SELF_HOSTED_WEBHOOK_HMAC_SECRET=

# ===== 可选：存储 =====
# GCS 用于持久化抓取结果（不设置则结果仅存 Redis）
GCS_BUCKET_NAME=
GCS_FIRE_ENGINE_BUCKET_NAME=

# ===== 可选：其他 =====
BULL_AUTH_KEY=@
LLAMAPARSE_API_KEY=
LOGGING_LEVEL=INFO
TEST_API_URL=http://localhost:3002
TEST_SUITE_WEBSITE=https://example.com
TEST_SUITE_SELF_HOSTED=true
