  "nodemonConfig": {
    "ignore": [
      "*.docx",
      "*.json",
      "temp"
    ]
  },
  "pnpm": {
    "allowScripts": {
      "oxc-resolver": true
    },
    "onlyBuiltDependencies": [
      "@lingcrawl/lingcrawl-rs",
      "bigint-buffer",
      "bufferutil",
      "four-flap-bigint-buffer",
      "keccak",
      "koffi",
      "libpq",
      "msgpackr-extract",
      "oxc-resolver",
      "protobufjs",
      "supabase",
      "utf-8-validate",
      "wordpos"
    ],
    "overrides": {
      "bigint-buffer": "npm:four-flap-bigint-buffer@1.1.6",
      "diff": "^8.0.3",
      "ajv": "^8.18.0",
      "fast-xml-parser": "^5.3.8",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "js-yaml@<3.14.2": ">=3.14.2",
      "qs@<6.14.2": ">=6.14.2",
      "minimatch@<10.2.3": ">=10.2.3",
      "bn.js@<5.2.3": ">=5.2.3",
      "@tootallnate/once@<3.0.1": ">=3.0.1"
    }
  },
  "packageManager": "pnpm@10.16.1"
}
