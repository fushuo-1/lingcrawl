    "joplin-turndown-plugin-gfm": "^1.0.12",
    "koffi": "^2.9.0",
    "marked": "^14.1.2",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.9.155",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "prom-client": "^15.1.3",
    "psl": "^1.15.0",
    "qs": "^6.15.0",
    "rate-limiter-flexible": "2.4.2",
    "robots-parser": "^3.0.1",
    "tldts": "^6.1.75",
    "tough-cookie": "^4.1.4",
    "turndown": "^7.1.3",
    "undici": "^7.18.2",
    "uuid": "^13.0.0",
    "winston": "^3.14.2",
    "ws": "^8.18.0",
    "xml2js": "^0.6.2",
    "zod": "4.1.12"
