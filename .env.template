# ================================================================
#  LingCrawl 完整配置模板
#  生成日期: 2026-06-03
#  基于: apps/api/src/config.ts + docker-compose.yaml + 源码扫描
#
#  标记说明:
#    [必填]  — 必须设置，否则服务无法启动
#    [推荐]  — 建议设置，影响核心功能
#    [可选]  — 有合理默认值，按需调整
#    [高级]  — 特殊场景才需要
# ================================================================


# ====== 服务基础 [必填] ======

PORT=3002                                    # API 服务端口
HOST=0.0.0.0                                 # 监听地址
ENV=local                                    # 运行环境: local / production
LOGGING_LEVEL=INFO                           # 日志级别: DEBUG / INFO / WARN / ERROR
IS_KUBERNETES=true                           # Docker/K8s 环境开启，使用 cgroup 读取容器级资源

# ====== 数据库 — PostgreSQL (NuQ 任务队列) [必填] ======

POSTGRES_HOST=nuq-postgres                   # PostgreSQL 主机
POSTGRES_PORT=5432                           # PostgreSQL 端口
POSTGRES_DB=postgres                         # 数据库名
POSTGRES_USER=postgres                       # 用户名
POSTGRES_PASSWORD=postgres                   # 密码

# harness 自动拼接以下两项；独立部署时需手动设置
# NUQ_DATABASE_URL=postgres://postgres:postgres@nuq-postgres:5432/postgres
# NUQ_DATABASE_URL_LISTEN=postgres://postgres:postgres@nuq-postgres:5432/postgres

# ====== 数据库 — Redis [必填] ======

REDIS_URL=redis://redis:6379                 # Redis 主连接
REDIS_RATE_LIMIT_URL=redis://redis:6379      # 速率限制用 Redis（可指向不同实例）
# REDIS_EVICT_URL=                           # [高级] 缓存驱逐用 Redis

# ====== 消息队列 — RabbitMQ (NuQ) [必填] ======

# NUQ_RABBITMQ_URL=amqp://rabbitmq:5672      # harness 自动设置；独立部署时需手动配置

# ====== SearXNG 搜索引擎 [推荐] ======

SEARXNG_ENDPOINT=http://searxng:8080         # SearXNG 地址（本地开发改为 http://localhost:8888）
SEARXNG_ENGINES=baidu,sogou,360search,quark,bing,google,duckduckgo,brave
SEARXNG_CATEGORIES=general                   # 搜索类别

# ====== 抓取引擎 [推荐] ======

PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape  # Playwright 微服务地址
# USE_GO_MARKDOWN_PARSER=false               # [可选] 启用 Go 高性能 Markdown 解析器

# ====== GitHub [可选] ======

GITHUB_TOKEN=                                # GitHub Personal Access Token（/github/read 端点需要）

# ====== 部署环境 [高级] ======

# IS_PRODUCTION=                             # 生产环境标识
# FIRE_ENGINE_BETA_URL=                      # Fire Engine Beta 地址
# SEARCH_PREVIEW_TOKEN=                      # 搜索预览 Token
# NUQ_POD_NAME=main                          # Pod 名称（多实例部署时区分）

# ====== 代理 [可选] ======

PROXY_SERVER=                                # HTTP/SOCKS5 代理地址
PROXY_USERNAME=                              # 代理用户名
PROXY_PASSWORD=                              # 代理密码

# ====== Worker 端口 [可选]（默认值适用于大多数场景） ======

# WORKER_PORT=3005                           # Worker 健康检查端口
# NUQ_WORKER_PORT=3000                       # NuQ Worker 端口
# NUQ_WORKER_START_PORT=3006                 # NuQ Worker 起始端口
# NUQ_WORKER_COUNT=5                         # NuQ Worker 实例数
# NUQ_PREFETCH_WORKER_PORT=3011              # 预取 Worker 端口
# NUQ_RECONCILER_WORKER_PORT=3012            # 协调 Worker 端口
# EXTRACT_WORKER_PORT=3004                   # Extract Worker 端口
# NUQ_WAIT_MODE=                             # [高级] NuQ 等待模式
# NUQ_PREFETCH_WORKER_HEARTBEAT_URL=         # [高级] 预取 Worker 心跳 URL

# ====== 抓取重试策略 [可选]（均有合理默认值） ======

# SCRAPE_MAX_ATTEMPTS=6                      # 最大重试次数（默认 6）
# SCRAPE_MAX_FEATURE_TOGGLES=3               # 功能切换重试上限（默认 3）
# SCRAPE_MAX_FEATURE_REMOVALS=3              # 功能移除重试上限（默认 3）
# SCRAPE_MAX_PDF_PREFETCHES=2                # PDF 预取重试上限（默认 2）
# SCRAPE_MAX_DOCUMENT_PREFETCHES=2            # 文档预取重试上限（默认 2）
# SCRAPEURL_ENGINE_WATERFALL_DELAY_MS=0      # 引擎瀑布流切换延迟（毫秒）

# ====== SSRF / 功能开关 [可选] ======

ALLOW_LOCAL_NETWORK=false                      # 允许抓取本地网络地址（测试用）
BLOCK_MEDIA=false                              # Playwright 拦截媒体资源（图片/视频/音频），提升抓取速度

# ====== 功能开关 [可选] ======

# FORCED_ENGINE_DOMAINS=                     # [高级] 强制指定引擎的域名映射
# LINGCRAWL_LOG_TO_FILE=false                # 日志写入文件

# ====== 系统资源限制 [可选] ======

# MAX_CPU=0.8                                # CPU 使用上限（默认 80%）
# MAX_RAM=0.8                                # 内存使用上限（默认 80%）
# SYS_INFO_MAX_CACHE_DURATION=150            # 系统信息缓存时长（秒）

# ====== Harness 开发工具 [可选] ======

# HARNESS_STARTUP_TIMEOUT_MS=60000           # harness 启动超时（ms）

# ====== 本地测试 [可选] ======

# TEST_API_URL=http://localhost:3002
# TEST_SUITE_WEBSITE=https://example.com
# TEST_SUITE_SELF_HOSTED=true
# TEST_API_KEY=
# TEST_TEAM_ID=
